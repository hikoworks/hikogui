{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "id": "hikogui-cspell-config",
  "name": "hikogui cspell Config",
  "language": "en-US",
  "minWordLength": 4,
  "globRoot": "../../",
  "files": [
    ".devcontainer/devcontainer.json",
    ".devcontainer/**/Dockerfile",
    ".devcontainer/scripts/*.sh",
    ".github/workflows/*.yml",
    ".github/**/*.md",
    "docs/**/*.md",
    "*.yml",
    "*.md",
    "src/**/*.cpp",
    "src/**/*.hpp"
  ],
  "ignorePaths": [
    ".git/*/**",
    ".git/!(COMMIT_EDITMSG)",
    ".vscode/**",
    ".clang-format",
    "*.bat",
    "*.cmake",
    "*.json",
    "*.lock",
    "*.log",
    "cspell.json",
    "cspell*.{json,yaml}",
    "LICENSE",
    "LICENSE_1_0.txt",
    "CMakeLists.txt",
    "CMakeOverride.txt",
    "hikogui.natvis",
    "tests/data/**",
    "data/ucd/**",
    "CMake/packaging/hikoguiResources.cmake.in",
    "docs/media/style/cppreference-doxygen-web.tag.xml",
    "docs/media/style/customdoxygen.css",
    "docs/media/style/DoxygenLayout.xml",
    "examples/hikogui_demo/resources/nl.po",
    "src/hikocpu/simd_f16x4_tests.cpp",
    "src/hikocpu/simd_f32x4_tests.cpp",
    "src/hikocpu/simd_f64x4_tests.cpp",
    "src/hikogui/GFX/renderdoc_app.h",
    "src/hikogui/i18n/iso_15924_impl.hpp",
    "src/hikogui/i18n/iso_15924_tests.cpp",
    "src/hikogui/i18n/language_tag_impl.hpp",
    "src/hikogui/path/glob_tests.cpp",
    "src/hikogui/path/glob_tests.cpp",
    "src/hikogui/unicode/ucd_scripts.hpp",
    "src/hikogui/unicode/unicode_plural.hpp",
    "src/hikothird/au.hh",
    "tools/generate_unicode_data.sh",
    "tools/ucd/generate_scripts.py",
    "src/hikogui/codec/base_n_tests.cpp",
    "src/hikogui/codec/datum_tests.cpp",
    "src/hikogui/char_maps/utf_8_tests.cpp",
    "src/hikogui/char_maps/utf_16_tests.cpp",
    "src/hikogui/char_maps/utf_32_tests.cpp",
    "src/hikogui/codec/SHA2_tests.cpp",
    "src/hikogui/codec/base_n_tests.cpp",
    "src/hikogui/codec/datum_tests.cpp",
    "src/hikogui/graphic_path/graphic_path_tests.cpp"
  ],
  "dictionaryDefinitions": [
    {
      "name": "repo-words",
      "addWords": true,
      "scope": [
        "workspace"
      ],
      "path": "./repo-words.txt",
      "description": "A list of words related to this repository."
    }
  ],
  "dictionaries": [
    "repo-words"
  ],
  "languageSettings": [
    {
      "languageId": "*",
      "allowCompoundWords": false
    },
    {
      "languageId": "markdown",
      "caseSensitive": true
    }
  ],
  "patterns": [
    {
      "name": "a-regexp",
      "pattern": "SOME_[A-Z]+_H_"
    }
  ],
  "ignoreRegExpList": [
    "a-regexp"
  ]
}