{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "id": "hikogui-cspell-config",
  "name": "hikogui cspell Config",
  "language": "en-US",
  "minWordLength": 4,
  "globRoot": "../../",
  "files": [
    ".devcontainer/devcontainer.json",
    ".devcontainer/**/Dockerfile",
    ".devcontainer/scripts/*.sh",
    ".github/workflows/*.yml",
    ".github/**/*.md",
    "docs/**/*.md",
    "*.yml",
    "*.md",
    "src/**/*.cpp",
    "src/**/*.hpp",
    "mod/**/*.ixx",
    "mod/**/*.cpp",
    "examples/**/*.cpp"
  ],
  "ignorePaths": [
    ".clang-format",
    ".git/!(COMMIT_EDITMSG)",
    ".git/*/**",
    ".vscode/**",
    "*.bat",
    "*.cmake",
    "*.json",
    "*.lock",
    "*.log",
    "CMakeLists.txt",
    "CMakeOverride.txt",
    "cspell.json",
    "cspell*.{json,yaml}",
    "hikogui.natvis",
    "LICENSE_1_0.txt",
    "LICENSE",
    "out/**",
    "CMake/packaging/hikoguiResources.cmake.in",
    "data/ucd/**",
    "docs/media/style/cppreference-doxygen-web.tag.xml",
    "docs/media/style/customdoxygen.css",
    "docs/media/style/DoxygenLayout.xml",
    "examples/custom_widgets/resources/copyright.md",
    "examples/hikogui_demo/resources/nl.po",
    "examples/widgets/text_example_impl.cpp",
    "mod/hikogui/audio/win32_device_interface.ixx",
    "mod/hikogui/audio/win32_wave_device.ixx",
    "mod/hikogui/char_maps/utf_16_tests.cpp",
    "mod/hikogui/char_maps/utf_32_tests.cpp",
    "mod/hikogui/char_maps/utf_8_tests.cpp",
    "mod/hikogui/codec/base_n_tests.cpp",
    "mod/hikogui/codec/datum_tests.cpp",
    "mod/hikogui/codec/inflate.ixx",
    "mod/hikogui/codec/png.ixx",
    "mod/hikogui/codec/SHA2_tests.cpp",
    "mod/hikogui/font/elusive_icon.ixx",
    "mod/hikogui/geometry/aarectangle.ixx",
    "mod/hikogui/geometry/circle.ixx",
    "mod/hikogui/geometry/matrix2.ixx",
    "mod/hikogui/geometry/matrix3.ixx",
    "mod/hikogui/geometry/perspective.ixx",
    "mod/hikogui/geometry/quad.ixx",
    "mod/hikogui/geometry/scale2.ixx",
    "mod/hikogui/geometry/scale3.ixx",
    "mod/hikogui/GFX/renderdoc_app.h",
    "mod/hikogui/GUI/gui_window_win32.ixx",
    "mod/hikogui/i18n/iso_15924_impl.ixx",
    "mod/hikogui/i18n/iso_15924_tests.cpp",
    "mod/hikogui/i18n/language_tag_impl.ixx",
    "mod/hikogui/path/glob_tests.cpp",
    "mod/hikogui/SIMD/**",
    "mod/hikogui/unicode/phrasing.ixx",
    "mod/hikogui/unicode/ucd_scripts.ixx",
    "mod/hikogui/unicode/unicode_plural.ixx",
    "mod/hikogui/utility/cast.ixx",
    "mod/hikogui/text/text_shaper.ixx",
    "patches/**",
    "resources/**",
    "tests/data/**",
    "src/hikocpu/array_intrinsic_f16x4_x86.hpp",
    "src/hikocpu/array_intrinsic_f32x4_x86.hpp",
    "src/hikocpu/array_intrinsic_f64x2_x86.hpp",
    "src/hikocpu/array_intrinsic_f64x4_x86.hpp",
    "src/hikocpu/cpu_id_x86.hpp",
    "src/hikocpu/float_to_half.hpp",
    "src/hikocpu/simd_f16x4_tests.cpp",
    "src/hikocpu/simd_f32x4_tests.cpp",
    "src/hikocpu/simd_f64x4_tests.cpp",
    "src/hikogui/audio/audio_device_win32.hpp",
    "src/hikogui/audio/audio_stream_format_win32.hpp",
    "src/hikogui/audio/win32_device_interface.hpp",
    "src/hikogui/audio/win32_wave_device.hpp",
    "src/hikogui/char_maps/utf_16_tests.cpp",
    "src/hikogui/char_maps/utf_32_tests.cpp",
    "src/hikogui/char_maps/utf_8_tests.cpp",
    "src/hikogui/codec/base_n_tests.cpp",
    "src/hikogui/codec/base_n_tests.cpp",
    "src/hikogui/codec/datum_tests.cpp",
    "src/hikogui/codec/datum_tests.cpp",
    "src/hikogui/codec/inflate.hpp",
    "src/hikogui/codec/png.hpp",
    "src/hikogui/codec/SHA2_tests.cpp",
    "src/hikogui/font/elusive_icon.hpp",
    "src/hikogui/font/true_type_font.hpp",
    "src/hikogui/geometry/aarectangle.hpp",
    "src/hikogui/geometry/circle.hpp",
    "src/hikogui/geometry/matrix2.hpp",
    "src/hikogui/geometry/matrix3.hpp",
    "src/hikogui/geometry/perspective.hpp",
    "src/hikogui/geometry/scale3.hpp",
    "src/hikogui/geometry/vector2.hpp",
    "src/hikogui/geometry/vector3.hpp",
    "src/hikogui/GFX/renderdoc_app.h",
    "src/hikogui/graphic_path/graphic_path_tests.cpp",
    "src/hikogui/GUI/gui_window_win32.hpp",
    "src/hikogui/i18n/iso_15924_impl.hpp",
    "src/hikogui/i18n/iso_15924_tests.cpp",
    "src/hikogui/i18n/language_tag_impl.hpp",
    "src/hikogui/path/glob_tests.cpp",
    "src/hikogui/path/glob_tests.cpp",
    "src/hikogui/unicode/ucd_scripts.hpp",
    "src/hikogui/unicode/unicode_plural.hpp",
    "src/hikogui/text/text_shaper.hpp",
    "src/hikothird/au.hh",
    "tools/generate_cmakelists.py",
    "tools/generate_unicode_data.sh",
    "tools/ucd/generate_scripts.py"
  ],
  "dictionaryDefinitions": [
    {
      "name": "repo-words",
      "addWords": true,
      "scope": [
        "workspace"
      ],
      "path": "./repo-words.txt",
      "description": "A list of words related to this repository."
    }
  ],
  "dictionaries": [
    "repo-words"
  ],
  "languageSettings": [
    {
      "languageId": "*",
      "allowCompoundWords": false
    },
    {
      "languageId": "markdown",
      "caseSensitive": true
    }
  ],
  "patterns": [
    {
      "name": "a-regexp",
      "pattern": "SOME_[A-Z]+_H_"
    }
  ],
  "ignoreRegExpList": [
    "a-regexp"
  ]
}